# Frontend (Vite) environment variables.
# All vars must be prefixed VITE_ and are read via import.meta.env.VITE_* (baked in at build time).
# Copy to .env.development / .env.production and fill in real values. Do NOT commit real client values.

# Backend API base URL. Leave empty to run the frontend in demo mode (mock data, no backend).
VITE_API_URL=http://localhost:5005

# Display name shown in the dashboard header. Falls back to "FlowDesk" if unset.
VITE_ORG_NAME=Your Org Name

# Reference/account ID shown under the header (with a copy button). Leave empty to hide the ID line.
VITE_ORG_ID=ORG-0000-XXX
