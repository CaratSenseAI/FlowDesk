PORT=5005
NODE_ENV=development

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Meta WhatsApp Cloud API
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
META_PHONE_ID="your_phone_number_id"
META_ACCESS_TOKEN="EAAxxxxx..."
META_VERIFY_TOKEN="flowdesk-webhook-secret"
# Set to "true" once task_assignment + task_escalation templates are approved by Meta
META_TEMPLATES_APPROVED="false"

# CORS — frontend origin
FRONTEND_URL="http://localhost:5173"

# Cloudinary — media storage for WhatsApp image/doc/audio attachments
# Sign up free at cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Voice Note Transcription ─────────────────────────────────────────────────
# Uses Groq Whisper (primary) — free tier: 7 200 audio min/day, ~200× real-time
# Sign up free at console.groq.com → API Keys
GROQ_API_KEY="gsk_xxxxxxxxxxxx"
# Override default Groq model (optional):
#   whisper-large-v3-turbo   ← default (fast + multilingual: EN/HI/MR)
#   whisper-large-v3         ← slightly more accurate
GROQ_ASR_MODEL="whisper-large-v3-turbo"

# OpenAI Whisper — fallback if no GROQ_API_KEY (paid, ~$0.006/min)
# Leave blank if you have a Groq key
OPENAI_API_KEY=""

# ── Intent Detection (semantic fallback) ─────────────────────────────────────
# Claude Haiku classifies voice notes that keyword matching misses
# Optional — keyword matching alone covers ~90% of cases
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"
